# Docker image
OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main

# Container naming
OPEN_WEBUI_CONTAINER_NAME=open-webui
NGINX_CONTAINER_NAME=open-webui-nginx

# Public host and HTTPS front door
PUBLIC_HOST=replace-with-public-host
WEBUI_URL=https://replace-with-public-host

# Public port mapping
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
OPEN_WEBUI_CONTAINER_PORT=8080

# Proxy -> host Ollama connectivity
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Open WebUI defaults
DEFAULT_USER_ROLE=user
TASK_MODEL=
TOOL_SERVER_CONNECTIONS=[]

# Open WebUI -> AI Defense proxy connectivity
AIDEFENSE_PROXY_PORT=8001
AIDEFENSE_BASE_URL=https://us.api.inspect.aidefense.security.cisco.com
AIDEFENSE_API_KEY=replace-on-host-only
AIDEFENSE_ENFORCEMENT_MODE=monitor
AIDEFENSE_ENABLED_RULES=
AIDEFENSE_INTEGRATION_PROFILE_ID=
AIDEFENSE_INTEGRATION_PROFILE_VERSION=
AIDEFENSE_INTEGRATION_TENANT_ID=
AIDEFENSE_INTEGRATION_TYPE=
AIDEFENSE_CONNECT_TIMEOUT_SECONDS=10
AIDEFENSE_READ_TIMEOUT_SECONDS=900
AIDEFENSE_WRITE_TIMEOUT_SECONDS=30
AIDEFENSE_POOL_TIMEOUT_SECONDS=30

# Cisco XDR MCP sidecar
MCP_XDR_PORT=8002
MCP_XDR_PATH=/mcp/
XDR_TOKEN_URL=https://visibility.amp.cisco.com/iroh/oauth2/token
XDR_CONURE_BASE_URL=https://conure.us.security.cisco.com
XDR_CLIENT_ID=
XDR_CLIENT_SECRET=
XDR_HTTP_TIMEOUT=30
XDR_VERIFY_TLS=true
XDR_TOKEN_REFRESH_SKEW_SECONDS=60

# Cisco XDR community MCP sidecar
XDR_MCP_COMMUNITY_COMMIT=replace-with-tested-commit
MCP_XDR_COMMUNITY_PORT=8004
MCP_XDR_COMMUNITY_PATH=/openapi.json
XDR_COMMUNITY_CLIENT_ID=
XDR_COMMUNITY_CLIENT_PASSWORD=
XDR_COMMUNITY_REGION=us
XDR_COMMUNITY_OAUTH_TOKEN_URL=
XDR_COMMUNITY_AUTOMATE_BASE_URL=
XDR_COMMUNITY_PLATFORM_BASE_URL=
XDR_COMMUNITY_PRIVATE_INTEL_BASE_URL=
XDR_COMMUNITY_CONURE_BASE_URL=

# Endace Vault MCP sidecar
MCP_ENDACE_VAULT_PORT=8003
MCP_ENDACE_VAULT_PATH=/mcp/
ENDACE_VAULT_BASE_URL=https://replace-with-vault-host/api/v5/vault
ENDACE_VAULT_USERNAME=
ENDACE_VAULT_PASSWORD=
ENDACE_VAULT_TIMEOUT=30
ENDACE_VAULT_VERIFY_TLS=false

# Cortex MCP sidecar
CORTEX_MCP_PAPI_URL=https://api-tenant.xdr.region.paloaltonetworks.com
CORTEX_MCP_PAPI_AUTH_HEADER=replace-with-cortex-standard-api-key
CORTEX_MCP_PAPI_AUTH_ID=
CORTEX_MCP_TRANSPORT=streamable-http
CORTEX_MCP_HOST=0.0.0.0
CORTEX_MCP_PORT=8080
CORTEX_MCP_PATH=/api/v1/stream/mcp
MCP_WRITE_TOOLS_ENABLED=false
MCP_ISOLATE_ENDPOINT_TOOL_ENABLED=false
MCP_ELICITATION_ENABLED=false

# Replace these before deployment with long random values.
WEBUI_SECRET_KEY=replace-with-a-long-random-secret
SCIM_TOKEN=replace-with-a-random-scim-token

# Open WebUI SCIM
SCIM_ENABLED=true
SCIM_AUTH_PROVIDER=oidc

# Open WebUI Duo OIDC SSO
ENABLE_OAUTH_SIGNUP=false
ENABLE_OAUTH_PERSISTENT_CONFIG=false
OAUTH_PROVIDER_NAME=Duo
OPENID_PROVIDER_URL=
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_SCOPES=openid email profile
OPENID_REDIRECT_URI=https://replace-with-public-host/oauth/oidc/callback
